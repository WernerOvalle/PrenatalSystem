# Added by fendo – supply chain protection
ignore-scripts=true
save-exact=true
minimum-release-age=10080
block-exotic-subdeps=true
trust-policy=no-downgrade
# node-options="--permission" deshabilitado: en CI/Vercel se aplica a
# NODE_OPTIONS y rompe `next build` (el modelo de permisos bloquea fsync y
# la lectura de los propios archivos de Next). No aporta seguridad en
# producción porque la salida es un export estático (sin runtime de Node).
# El modelo de permisos se mantiene en local vía los flags --permission de
# los scripts dev/lint/preview en package.json.
